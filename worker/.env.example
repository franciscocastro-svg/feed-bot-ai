# Required server-side values. Fill only in the VPS secret environment.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=

# Optional providers and tuning.
GROQ_API_KEY=
XAI_API_KEY=
CUT_TRANSCRIPTION_PROVIDERS=groq,gemini
CUT_ANALYSIS_PROVIDERS=gemini,xai
CUT_SUBTITLE_LEAD_MS=80
GEMINI_TEXT_MODEL=
GEMINI_TRANSCRIBE_MODEL=
GEMINI_CUT_ANALYSIS_MODEL=
GEMINI_FACE_MODEL=
GROQ_WHISPER_MODEL=
XAI_BASE_URL=
XAI_CUT_MODEL=

# Optional YouTube extraction configuration.
YT_COOKIES_FILE=
YT_DLP_REMOTE_COMPONENTS=
YT_DLP_EXTRACTOR_ARGS=
YT_DLP_USER_AGENT=

# Process identity is normally supplied by ecosystem.config.cjs.
WORKER_ID=
WORKER_QUEUES=
WORKER_VERSION=
